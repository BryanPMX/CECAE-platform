APP_ENV=development
APP_NAME=cecae-api
APP_LOG_LEVEL=info

HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

POSTGRES_DB=cecae
POSTGRES_USER=cecae
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_PORT=5432
API_PORT=8080
CECAE_API_TAG=local

DATABASE_URL=postgres://cecae:replace-with-a-strong-postgres-password@postgres:5432/cecae?sslmode=disable
DATABASE_MIN_CONNS=1
DATABASE_MAX_CONNS=10
DATABASE_MAX_CONN_LIFETIME=1h
DATABASE_MIGRATIONS_PATH=file:///app/migrations

AUTH_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters
AUTH_REFRESH_TOKEN_SECRET=replace-with-a-different-32-character-secret
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=720h

# Used only when running the optional admin-bootstrap compose profile.
ADMIN_EMAIL=admin@cecae.org
ADMIN_PASSWORD=replace-with-a-strong-admin-password

CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
